# ─────────────────────────────────────────────────────────────
# Copy this file to `.env.local` for local development.
# On Vercel, these are set automatically when you add a Postgres
# store (Storage tab → Create → Postgres). No manual copying needed.
# ─────────────────────────────────────────────────────────────

# Vercel Postgres connection string.
# Leave blank locally to use the JSON file fallback (.data/rsvps.json).
POSTGRES_URL=

# Password for the private guest-list / carpool admin dashboard (/admin).
# Change this to something only the hosts know.
ADMIN_PASSWORD=changeme
